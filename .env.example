AI_PROVIDER=mock
AI_MODEL=mock-resume-rewriter

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/zesume?schema=public"
DATABASE_RUNTIME_ENABLED=false
AUTH_DATABASE_ENABLED=false
GUEST_GENERATION_LIMIT=1

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_THINKING=disabled

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_URL=http://localhost:3000

# PayPal Orders v2. Keep client secrets out of source control and use
# Cloudflare Worker Secrets in production.
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Optional. When blank, Zesume creates and stores the webhook automatically.
PAYPAL_WEBHOOK_ID=
