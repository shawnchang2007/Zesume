    "prisma:migrate": "prisma migrate dev",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@prisma/client": "^7.8.0",
    "docx": "^9.7.1",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "prisma": "^7.8.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.110.0"
  }
}
