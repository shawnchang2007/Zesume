{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "zesume",
  "main": ".open-next/worker.js",
  "workers_dev": true,
  "preview_urls": true,
  "compatibility_date": "2026-07-10",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "routes": [
    {
      "pattern": "zesume.xyz",
      "custom_domain": true
    },
    {
      "pattern": "www.zesume.xyz",
      "custom_domain": true
    }
  ],
  "vars": {
    "AI_PROVIDER": "mock",
    "DEEPSEEK_MODEL": "deepseek-v4-flash",
    "DATABASE_URL": "postgresql://user:password@localhost:5432/zesume?schema=public"
  },
  "observability": {
    "enabled": true
  }
}
