{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "zesume",
  "main": ".open-next/worker.js",
  "workers_dev": true,
  "preview_urls": true,
  "compatibility_date": "2026-07-10",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "routes": [
    {
      "pattern": "zesume.xyz",
      "custom_domain": true
    },
    {
      "pattern": "www.zesume.xyz",
      "custom_domain": true
    }
  ],
  "vars": {
    "AUTH_URL": "https://zesume.xyz",
    "AUTH_GOOGLE_ID": "870373804988-l930cjtoag0khuu4u1s3kjg75ffpr1qo.apps.googleusercontent.com",
    "AI_PROVIDER": "deepseek",
    "DEEPSEEK_MODEL": "deepseek-v4-flash",
    "AI_REQUEST_TIMEOUT_MS": "45000",
    "DATABASE_RUNTIME_ENABLED": "true",
    "AUTH_DATABASE_ENABLED": "true"
  },
  "ratelimits": [
    {
      "name": "RESUME_REWRITE_RATE_LIMITER",
      "namespace_id": "2026071001",
      "simple": {
        "limit": 10,
        "period": 60
      }
    }
  ],
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "invocation_logs": true,
      "head_sampling_rate": 1
    },
    "traces": {
      "enabled": true,
      "head_sampling_rate": 0.1
    }
  }
}
